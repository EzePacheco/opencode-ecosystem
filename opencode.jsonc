{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "plan",
  // Native-root MCP policy: keep agent-memory disabled and keep other MCPs
  // documented first unless a later spec defines safe platform-specific config.
  "mcp": {
    "agent-memory": {
      "type": "local",
      "command": ["{env:HOME}/.agent-memory/bin/agent-memory", "mcp"],
      "enabled": false
    }
  },
  "permission": {
    "agent-memory_*": "deny"
  },
  "references": {
    "standards": {
      "path": "./standards",
      "description": "Use for global engineering, architecture, security, testing, and opencode workflow standards. Start with INDEX.md."
    }
  }
}
